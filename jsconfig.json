{
  "compilerOptions": {
    "checkJs": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2020",
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "#r/*": ["./src/*"],
      "#commons/*": ["./src/modules/commons/*"],
      "#libs/*": ["./src/libs/*"],
      "#c": ["./src/constants.js"],
      "#modules/*": ["./src/modules/*"]
    }
  },
  "include": ["./src", "./types.d.ts"]
}
